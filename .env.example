# Lucera AI-DR — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# ── AI APIs (server-only) ─────────────────────────────────────────────────────

# OpenAI API key
# Used in: /api/ai-check (gpt-3.5-turbo) and /api/mini-check LLM interpretation (gpt-4.1-mini)
OPENAI_API_KEY=

# Anthropic API key
# Used in: /api/ai-check (claude-sonnet-4-20250514)
ANTHROPIC_API_KEY=

# ── Email (server-only) ───────────────────────────────────────────────────────

# Resend API key
# Used in: /api/lead, /api/form, /api/session-summary
# Sender domain reports@lucera.site must be verified in Resend dashboard
RESEND_API_KEY=

# ── Analytics (public — baked into client bundle at build time) ───────────────

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# GA loads only after cookie consent. Leave empty to disable GA entirely.
NEXT_PUBLIC_GA_ID=

# ── Optional / not confirmed active ──────────────────────────────────────────

# Rate limiting override — present in .env.local but rate limits are currently
# hardcoded in route files (30/hr mini-check, 10/hr ai-check).
# MAX_REQUESTS_PER_HOUR=
